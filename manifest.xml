<iq:manifest version="3" xmlns:iq="http://www.garmin.com/xml/connectiq">
    <!--
        Passed Note - a watch face that looks like a note teenagers pass to each
        other in class: lined notebook paper, a red margin, punch holes, and every
        piece of data written in a different handwriting - blue and black ballpoint
        pen. Targets CIQ 4.0+ round watches that support watch faces. Square /
        rectangular panels are excluded - the layout is designed for round screens.

        The face is laid out relative to dc.getWidth()/getHeight(), and
        tools/gen_fonts.py bakes a correctly-sized bitmap font set (Segoe Script,
        Segoe Print, Ink Free) for each distinct resolution; monkey.jungle maps
        every product to its set.
    -->
    <iq:application id="f4d2fabe-e5b8-45be-b6ad-ccdf43808b2a" type="watchface" name="@Strings.AppName" entry="NotebookApp" launcherIcon="@Drawables.LauncherIcon" minApiLevel="4.0.0">
        <iq:products>
            <!-- Forerunner -->
            <iq:product id="fr165"/>
            <iq:product id="fr165m"/>
            <iq:product id="fr255"/>
            <iq:product id="fr255m"/>
            <iq:product id="fr255s"/>
            <iq:product id="fr255sm"/>
            <iq:product id="fr265"/>
            <iq:product id="fr265s"/>
