# Normalize line endings: let Git decide text vs binary, store text as LF in the repo
* text=auto

# Explicit text formats (stored as LF in the repo)
*.xml    text
*.yml    text
*.yaml   text
*.md     text
*.py     text
*.mc     text
*.txt    text
*.svg    text
*.jungle text
*.fnt    text
*.gitignore text
LICENSE  text
CODEOWNERS text

# Windows-native scripts: keep CRLF in the working tree
*.ps1 text eol=crlf
*.bat text eol=crlf

# Binary assets (never touch line endings)
*.png binary
*.jpg binary
*.ttf binary
